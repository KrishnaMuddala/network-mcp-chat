# Local LLM settings (Ollama)
MCP_SERVER_URL=http://localhost:8000/mcp
LOCAL_LLM_MODEL=qwen2.5:7b #qwen3.5:0.8b
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
FORWARD_API_KEY=<<your API key>>
FORWARD_API_SECRET=<<your Forward api key>>
FORWARD_API_BASE_URL=https://fwd.app
FORWARD_DEFAULT_NETWORK_ID = <<your Fwd network id>>

CISCO_DEVICE_HOST = "device ip"
CISCO_DEVICE_USER = "<<device username>>"
CISCO_DEVICE_PASS = "<<device password>>"
CISCO_DEVICE_PORT = 22

# If you want to use a different OpenAI-compatible server (LM Studio, vLLM, etc.)
# just change LOCAL_LLM_BASE_URL and LOCAL_LLM_MODEL accordingly.
# e.g. LM Studio:  LOCAL_LLM_BASE_URL=http://localhost:1234/v1
